{
  "name": "second-brain-poc",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "vercel dev",
    "webapp:dev": "npm --prefix webapp run dev",
    "webapp:build": "npm --prefix webapp run build",
    "webapp:preview": "npm --prefix webapp run preview",
    "second-brain:start": "npm --prefix second-brain run start",
    "second-brain:android": "npm --prefix second-brain run android",
    "second-brain:ios": "npm --prefix second-brain run ios",
    "second-brain:web": "npm --prefix second-brain run web",
    "open-brain:start": "npm --prefix open-brain run start",
    "open-brain:android": "npm --prefix open-brain run android",
    "open-brain:ios": "npm --prefix open-brain run ios",
    "open-brain:web": "npm --prefix open-brain run web",
    "setup": "npm install && cd webapp && npm install",
    "migrate": "node lib/db.js",
    "webhook:set": "node scripts/set-webhook.js",
    "webhook:del": "node scripts/del-webhook.js",
    "start:api": "node --watch --watch-path=api --watch-path=lib scripts/local-api.js",
    "test": "node --test tests/api/*.test.js && npm --prefix second-brain run test && npm --prefix open-brain run test"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "expo": "^55.0.23",
    "express": "^4.18.2",
    "groq-sdk": "^0.9.1",
    "playwright": "^1.60.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "react-dom": "19.2.0",
    "react-native-web": "^0.21.0"
  },
  "overrides": {
    "glob": "^13.0.0"
  },
  "engines": {
    "node": "24.x"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.3"
  }
}
