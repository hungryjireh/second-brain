# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Groq (Whisper transcription + LLaMA classification)
GROQ_API_KEY=your_groq_api_key_here

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_here
TELEGRAM_TOKEN_ENCRYPTION_KEY=your_strong_random_token_encryption_key_here
# JWT secret auth (generate with: openssl rand -hex 32)
JWT_SECRET=your_strong_random_jwt_secret_here
AUTH_USERNAME=admin
AUTH_PASSWORD=admin

# Webhook registration (only needed when running set-webhook.js)
VERCEL_URL=https://your-app.vercel.app
WEBHOOK_LOCAL_FALLBACK_URL=http://localhost:3000

# For Expo/mobile, use your machine LAN IP when testing on a physical device.
EXPO_PUBLIC_API_URL=http://localhost:3000/api
