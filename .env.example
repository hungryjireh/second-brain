# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_personal_chat_id_here
TELEGRAM_WEBHOOK_SECRET=any_random_string_32_chars   # optional but recommended
TELEGRAM_USER_ID=you@example.com

# Groq (Whisper transcription + LLaMA classification)
GROQ_API_KEY=your_groq_api_key_here

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_here
# JWT secret auth (generate with: openssl rand -hex 32)
JWT_SECRET=your_strong_random_jwt_secret_here
AUTH_USERNAME=admin
AUTH_PASSWORD=admin

# Webhook registration (only needed when running set-webhook.js)
VERCEL_URL=https://your-app.vercel.app
WEBHOOK_LOCAL_FALLBACK_URL=http://localhost:3000
