# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_personal_chat_id_here
TELEGRAM_WEBHOOK_SECRET=any_random_string_32_chars   # optional but recommended

# Groq (Whisper transcription + LLaMA classification)
GROQ_API_KEY=your_groq_api_key_here

# Turso (SQLite-compatible edge DB)
TURSO_DATABASE_URL=libsql://your-db-name-org.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token_here

# Vercel Cron auth (generate with: openssl rand -hex 32)
CRON_SECRET=your_cron_secret_here

# Webhook registration (only needed when running set-webhook.js)
VERCEL_URL=https://your-app.vercel.app
